{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://book-quiz-lab.replit.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
